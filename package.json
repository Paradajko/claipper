{
  "name": "claipper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "railway run npm run dev:local:processes",
    "dev:local:processes": "FFMPEG_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg FFPROBE_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffprobe WORKER_ID=claipper-mac concurrently --kill-others-on-fail --names web,agent,worker --prefix-colors cyan,green,yellow \"next dev -H 127.0.0.1 -p 3000\" \"npm:worker:local-agent\" \"npm:worker:stream-scan\"",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "dev:reset-stream-scan": "node scripts/dev-reset-stream-scan.mjs",
    "worker:stream-scan": "node workers/stream-scan-worker.mjs",
    "worker:local-agent": "node workers/local-agent.mjs",
    "worker:smoke-test": "node workers/stream-scan-smoke-test.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/lib-storage": "^3.1085.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/multipart": "^10.1.0",
    "@supabase/supabase-js": "^2.48.1",
    "clsx": "^2.1.1",
    "fastify": "^5.10.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
